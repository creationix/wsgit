    "@vercel/functions": "https://vercel-h2j0px0hh.vercel.sh/tarballs/%40vercel/functions.tgz",
    "@vercel/oidc-aws-credentials-provider": "^3.0.7",
    "next": "^16.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
