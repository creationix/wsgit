{
  "name": "ws-git",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "git-remote-wsgit": "packages/client/dist/remote-helper.js",
    "wsgit-server": "packages/server/dist/cli.js"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "next dev",
