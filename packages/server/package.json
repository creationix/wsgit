    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@ws-git/protocol": "*",
    "ws": "^8.18.0",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "@types/better-sqlite3": "^7.6.0",
    "tsx": "^4.19.0"
  }
}